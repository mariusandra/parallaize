[Unit]
Description=Parallaize Caddy front door
After=network-online.target parallaize.service
Wants=network-online.target

[Service]
Type=simple
User=parallaize
Group=parallaize
WorkingDirectory=/opt/parallaize
ExecStart=/usr/bin/env bash -lc 'flox activate -d /opt/parallaize -- caddy run --config /opt/parallaize/infra/Caddyfile'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
