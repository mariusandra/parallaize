{
  "name": "parallaize",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "description": "Server-first proof of concept for managing many isolated desktop environments.",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-static.mjs && node scripts/build-web.mjs",
    "build:web": "node scripts/copy-static.mjs && node scripts/build-web.mjs",
    "start": "PARALLAIZE_PROVIDER=incus PARALLAIZE_DATA_FILE=data/incus-state.json node dist/apps/control/src/server.js",
    "start:mock": "PARALLAIZE_PROVIDER=mock PARALLAIZE_DATA_FILE=data/state.json node dist/apps/control/src/server.js",
    "dev": "pnpm build && pnpm start",
    "smoke:incus": "node scripts/smoke-incus.mjs",
    "persistence:export": "pnpm build && node dist/apps/control/src/persistence-cli.js export",
    "persistence:import": "pnpm build && node dist/apps/control/src/persistence-cli.js import",
    "persistence:copy": "pnpm build && node dist/apps/control/src/persistence-cli.js copy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test dist/tests/*.test.js",
    "package:prepare": "pnpm build && node scripts/build-package-runtime.mjs",
    "package:deb": "pnpm package:prepare && node scripts/build-packages.mjs --format deb --arch amd64",
    "package:deb:arm64": "pnpm package:prepare && node scripts/build-packages.mjs --format deb --arch arm64",
    "package:release": "pnpm package:prepare && node scripts/build-packages.mjs --format deb --arch amd64,arm64",
    "release:version": "node scripts/update-release-version.mjs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.10",
    "tailwindcss": "^4.1.13"
  },
  "dependencies": {
    "@novnc/novnc": "^1.6.0",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "ws": "^8.19.0"
  }
}
