PARALLAIZE_APP_HOME=/usr/lib/parallaize

HOST=127.0.0.1
PORT=3000
PARALLAIZE_CADDY_PORT=8080

PARALLAIZE_PROVIDER=incus
PARALLAIZE_PERSISTENCE=json
PARALLAIZE_DATA_FILE=/var/lib/parallaize/state.json

# Uncomment these when you want PostgreSQL-backed state instead of the JSON file.
# PARALLAIZE_PERSISTENCE=postgres
# PARALLAIZE_DATABASE_URL=postgresql://parallaize:parallaize@127.0.0.1:5432/parallaize

PARALLAIZE_INCUS_BIN=/usr/bin/incus
PARALLAIZE_INCUS_PROJECT=
# Packaged installs bootstrap a default pool named "default" on blank Ubuntu
# hosts. Blank hosts prefer btrfs and fall back to dir if needed.
PARALLAIZE_INCUS_STORAGE_POOL=default
PARALLAIZE_TEMPLATE_COMPRESSION=none
PARALLAIZE_GUEST_VNC_PORT=5900
PARALLAIZE_GUEST_INOTIFY_MAX_USER_WATCHES=1048576
PARALLAIZE_GUEST_INOTIFY_MAX_USER_INSTANCES=2048

PARALLAIZE_ADMIN_USERNAME=admin
PARALLAIZE_ADMIN_PASSWORD=change-me

# Persisted admin-session defaults: seven-day absolute lifetime, 24-hour idle
# timeout, and six-hour secret rotation.
# PARALLAIZE_SESSION_MAX_AGE_SECONDS=604800
# PARALLAIZE_SESSION_IDLE_TIMEOUT_SECONDS=86400
# PARALLAIZE_SESSION_ROTATION_SECONDS=21600
