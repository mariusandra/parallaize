PARALLAIZE_APP_HOME=/usr/lib/parallaize

HOST=127.0.0.1
PORT=3000
PARALLAIZE_CADDY_PORT=8080

PARALLAIZE_PROVIDER=incus
PARALLAIZE_PERSISTENCE=json
PARALLAIZE_DATA_FILE=/var/lib/parallaize/state.json

# Uncomment these when you want PostgreSQL-backed state instead of the JSON file.
# PARALLAIZE_PERSISTENCE=postgres
# PARALLAIZE_DATABASE_URL=postgresql://parallaize:REPLACE_WITH_STRONG_PASSWORD@127.0.0.1:5432/parallaize

PARALLAIZE_INCUS_BIN=/usr/bin/incus
PARALLAIZE_INCUS_PROJECT=
# Packaged installs bootstrap a default pool named "default" on blank Ubuntu
# hosts. Blank hosts prefer btrfs and fall back to dir if needed.
PARALLAIZE_INCUS_STORAGE_POOL=default
PARALLAIZE_TEMPLATE_COMPRESSION=none
# Keep hostname-based forwarded services on an HTTPS-safe localhost suffix by
# default. Change this to your wildcard domain when you have one.
PARALLAIZE_FORWARDED_SERVICE_HOST_BASE=parallaize.localhost
PARALLAIZE_GUEST_VNC_PORT=5900
PARALLAIZE_GUEST_SELKIES_PORT=6080
# Guacamole uses a host-local guacd daemon and the same guest x11vnc listener
# as the direct VNC browser path.
PARALLAIZE_GUACD_HOST=127.0.0.1
PARALLAIZE_GUACD_PORT=4822
# Remote Selkies sessions usually need an explicit TURN/STUN deployment once
# users connect through NAT, a reverse proxy, or the public internet.
# PARALLAIZE_SELKIES_STUN_HOST=stun.example.com
# PARALLAIZE_SELKIES_STUN_PORT=3478
# PARALLAIZE_SELKIES_TURN_HOST=turn.example.com
# PARALLAIZE_SELKIES_TURN_PORT=5349
# PARALLAIZE_SELKIES_TURN_PROTOCOL=tcp
# PARALLAIZE_SELKIES_TURN_TLS=true
# PARALLAIZE_SELKIES_TURN_SHARED_SECRET=
# PARALLAIZE_SELKIES_TURN_USERNAME=
# PARALLAIZE_SELKIES_TURN_PASSWORD=
# PARALLAIZE_SELKIES_TURN_REST_URI=
# PARALLAIZE_SELKIES_TURN_REST_USERNAME=
# PARALLAIZE_SELKIES_TURN_REST_USERNAME_AUTH_HEADER=
# PARALLAIZE_SELKIES_TURN_REST_PROTOCOL_HEADER=
# PARALLAIZE_SELKIES_TURN_REST_TLS_HEADER=
PARALLAIZE_GUEST_INOTIFY_MAX_USER_WATCHES=1048576
PARALLAIZE_GUEST_INOTIFY_MAX_USER_INSTANCES=2048

PARALLAIZE_ADMIN_USERNAME=admin
PARALLAIZE_ADMIN_PASSWORD=change-me

# Persisted admin-session defaults: seven-day absolute lifetime, 24-hour idle
# timeout, and six-hour secret rotation.
# PARALLAIZE_SESSION_MAX_AGE_SECONDS=604800
# PARALLAIZE_SESSION_IDLE_TIMEOUT_SECONDS=86400
# PARALLAIZE_SESSION_ROTATION_SECONDS=21600

# Optional release metadata used by the sidebar update indicator.
# PARALLAIZE_RELEASE_METADATA_URL=https://parallaize.com/latest.json
